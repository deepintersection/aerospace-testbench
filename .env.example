# aerospace-testbench — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://testbench:testbench_dev@localhost:5432/testbench

# ── API ──────────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true            # set to false in production
LOG_LEVEL=INFO

# ── Instrument layer ─────────────────────────────────────────────────────────
# Set to "sim" for offline development (uses pyvisa-sim)
# Set to "visa" for real hardware (requires NI-VISA or linux-gpib on host)
INSTRUMENT_BACKEND=sim

# Path to pyvisa-sim instrument definition file (used when INSTRUMENT_BACKEND=sim)
PYVISA_SIM_FILE=instruments/sim/testbench.yaml

# Default VISA communication timeout in milliseconds
VISA_TIMEOUT_MS=5000

# ── pgAdmin (dev profile only: docker compose --profile dev up) ───────────────
PGADMIN_EMAIL=pgadmin@testbench.local
PGADMIN_PASSWORD=change-me
PGADMIN_PORT=5050
SECRET_KEY=change-me-before-any-real-use
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Bokeh dashboard ───────────────────────────────────────────────────────────
BOKEH_HOST=127.0.0.1
BOKEH_PORT=5006
